@model List<ResultBasketDto>
@{
    Layout = null;
    int count = 0;
    decimal basketTotalPrice = 0;
    decimal basketTotalPriceWithTax = 0;
    decimal tax = 0;
    decimal totalPrice = 0;
}


<!DOCTYPE html>
<html>

     @await Component.InvokeAsync("_UILayoutHeadComponentPartial")

<body class="sub_page">

     @await Component.InvokeAsync("_UILayoutNavbarComponentPartial")  
  </div>
  <br /><br />
<div class="container-fluid py-5">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-dark mb-4 p-3 rounded">
                <a class="breadcrumb-item text-white" href="/Default/Index/">Ana Sayfa</a>
                <a class="breadcrumb-item text-white" href="/Menu/Index/">Menü</a>
                <span class="breadcrumb-item active text-warning">Sepetiniz</span>
            </nav>
        </div>
    </div>

    <div class="row px-xl-5 align-items-stretch">
        <!-- SEPET TABLOSU -->
        <div class="col-lg-8 mb-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-0">
                    <table class="table table-striped table-hover text-center mb-0">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th>#</th>
                                <th>Ürün Adı</th>
                                <th>Adet</th>
                                <th>Fiyat</th>
                                <th>Toplam</th>
                                <th>Sil</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                    basketTotalPrice = Model.Sum(x => x.Price);
                                    tax = basketTotalPrice * 10 / 100;
                                    basketTotalPriceWithTax = basketTotalPrice + tax;
                                    count++;
                                    totalPrice = item.Count * item.Price;
                                <tr>
                                    <td>@count</td>
                                    <td>@item.ProductName</td>
                                    <td>@item.Count</td>
                                    <td>@item.Price ₺</td>
                                    <td>@totalPrice.ToString("0.00") ₺</td>
                                    <td>
                                        <a  class="btn btn-sm btn-danger" href="/Baskets/DeleteBasket/@item.BasketID">
                                            <i class="fa fa-times"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <!-- SEPET ÖZETİ -->
        <div class="col-lg-4 mb-5 d-flex">
            <div class="card shadow-sm border-0 flex-grow-1 d-flex flex-column h-100">
                <div class="card-body d-flex flex-column justify-content-between h-100">

                    <!-- Kupon Alanı -->
                    <form class="mb-4">
                        <div class="input-group">
                            <input type="text" id="couponcode" class="form-control p-3" placeholder="Kupon Kodunuz">
                            <button type="button" class="btn btn-warning fw-bold px-4" id="btncouponecode">Kuponu Uygula</button>
                        </div>
                    </form>

                    <!-- Sepet Özeti -->
                    <div class="flex-grow-1 d-flex flex-column justify-content-between">
                        <div>
                            <h5 class="section-title text-uppercase mb-3">
                                <span class="bg-secondary text-white px-2 py-1 rounded">Sepet Özeti</span>
                            </h5>

                            <div class="border-top pt-3">
                                <div class="d-flex justify-content-between mb-2">
                                    <h6>Toplam Tutar</h6>
                                    <h6><span id="totalprice">@basketTotalPrice</span> ₺</h6>
                                </div>
                                <div class="d-flex justify-content-between mb-2">
                                    <h6>KDV Oranı</h6>
                                    <h6><span id="kdv">@tax</span> ₺</h6>
                                </div>
                                <hr>
                                <div class="d-flex justify-content-between">
                                    <h5>Genel Toplam</h5>
                                    <h5><span id="totalpricewithkdv">@basketTotalPriceWithTax</span> ₺</h5>
                                </div>
                            </div>
                        </div>

                        <button id="btnchecked" class="btn btn-warning btn-block w-100 mt-4 fw-bold">
                            Siparişi Tamamla
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


    @await Component.InvokeAsync("_UILayoutFooterComponentPartial")
 
  @await Component.InvokeAsync("_UILayoutScriptComponentPartial")

</body>

</html>