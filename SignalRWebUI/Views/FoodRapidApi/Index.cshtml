@model List<Result>
@{
    ViewData["Title"] = "Index";
    Layout = null;
}

<!DOCTYPE html>
<html>

     @await Component.InvokeAsync("_UILayoutHeadComponentPartial")

<body class="sub_page">

     @await Component.InvokeAsync("_UILayoutNavbarComponentPartial")  
  </div>
  <br /><br />
<div class="container-fluid py-5">
    <div class="row px-xl-5">
        <div class="col-12">
            <nav class="breadcrumb bg-dark mb-4 p-3 rounded">
                <a class="breadcrumb-item text-white" href="/Default/Index/">Ana Sayfa</a>
                <a class="breadcrumb-item text-white" href="/Menu/Index/">Api Listesi</a>
                <span class="breadcrumb-item active text-warning">Tasty Api</span>
            </nav>
        </div>
    </div>

    <div class="row px-xl-5 align-items-stretch">
        <!-- SEPET TABLOSU -->
        <div class="col-lg-12 mb-5">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-0">
                    <table class="table table-striped table-hover text-center mb-0">
                        <thead class="bg-dark text-white">
                            <tr>
                                 <th>Görsel</th>
                                 <th>Ad</th>
                                 <th>Süre (dk)</th>
                                 <th>Video</th>
                            </tr>
                        </thead>  
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td><img src="@item.thumbnail_url" style="width:80px; height:80px" /></td>
                                    <td>@item.name</td>
                                    @{
                                        if(item.total_time_minutes == 0)
                                        {
                                            <td>15</td>
                                        }
                                        else
                                        {
                                            <td>@item.total_time_minutes</td>
                                        }
                                    }                                                                      
                                    <td>
                    <a href="@item.original_video_url" target="_blank" class="btn btn-warning">
                        Tarifi İzle
                    </a>
                                    </td>
                                </tr>                           
                                
                            }
                    </table>
                </div>
            </div>
        </div>
        
       
          
        </div>
    </div>
</div>


    @await Component.InvokeAsync("_UILayoutFooterComponentPartial")
 
  @await Component.InvokeAsync("_UILayoutScriptComponentPartial")

</body>

</html>

